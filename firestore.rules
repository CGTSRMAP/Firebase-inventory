rules_version = '2';

// ── Campus Inventory — Firestore security rules ──────────────────────────────
// The login screen in manage.html is convenience, NOT security. These rules are
// what actually protect your data on Google's servers. Deploy them, or anyone
// could write to your database regardless of the login UI.
//
// Model:
//   • Anyone may READ equipment and contacts  → the public finder (index.html)
//     needs this to show results without a login.
//   • Only SIGNED-IN users may WRITE (add / edit / delete) → that's your admins,
//     whom you create under Authentication in the Firebase console.
//
// To deploy: Firebase console → Firestore Database → Rules → paste → Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    match /equipment/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /contacts/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ── Hardening to consider as you grow (notes, not active rules) ──────────────
// 1. Hide cost from the public. Firestore can't hide individual fields on read,
//    so keep purchase price / vendor / funding in a separate `equipment_private`
//    collection that requires `request.auth != null` to read. The public finder
//    reads `equipment`; the admin console reads both.
// 2. Multi-college isolation. When several colleges share one project, give each
//    admin a custom claim `collegeId` and require
//      allow write: if request.auth.token.collegeId == request.resource.data.collegeId;
//    so one college's admin can never edit another's records.
